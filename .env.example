# ─────────────────────────────────────────────────────────────────────────────
# IBM watsonx.ai — used for RAG embeddings (ibm/slate-125m-english-rtrvr)
#
# FREE setup (no credit card needed):
#   1. Go to https://cloud.ibm.com  → Create account with email only (Lite tier)
#   2. Search "Watson Machine Learning" → Create instance (Lite plan = free)
#   3. Go to https://dataplatform.cloud.ibm.com → Create a project
#   4. Copy your Project ID from project settings
#   5. Go to https://cloud.ibm.com/iam/apikeys → Create API key
#
# If left blank → automatically falls back to local sentence-transformers model.
# ─────────────────────────────────────────────────────────────────────────────
WATSONX_API_KEY=your_ibm_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─────────────────────────────────────────────────────────────────────────────
# Groq — used for LLM generation (llama-3.3-70b-versatile)
# Free API key at https://console.groq.com
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# Backend
BACKEND_PORT=8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
